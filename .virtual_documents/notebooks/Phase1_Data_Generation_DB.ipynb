import numpy as np
import pandas as pd
import pymysql
from pymysql.cursors import DictCursor
from datetime import datetime, timedelta
import random
import os
from dotenv import load_dotenv


load_dotenv("../.env")


DB_NAME = os.getenv('DB_NAME')
DB_USER = os.getenv('DB_USER')
DB_PASSWORD = os.getenv('DB_PASSWORD')
DB_HOST = os.getenv('DB_HOST')
DB_PORT = int(os.getenv('DB_PORT'))

EPSILON = float(os.getenv('EPSILON'))


# Simulation parameters
START_DATE = datetime(2023, 1, 1, 0, 0, 0)
NUM_HOURS = 24 * 365
BASE_CONSUMPTION = 0.8 
SEASONAL_AMPLITUDE = 0.4
DAILY_AMPLITUDE = 0.3
RANDOM_NOISE_SCALE = 0.1


dates = [START_DATE + timedelta(hours=i) for i in range(NUM_HOURS)]
df = pd.DataFrame({'timestamp': dates})
df['hour'] = df['timestamp'].dt.hour
df['day_of_year'] = df['timestamp'].dt.dayofyear
df['month'] = df['timestamp'].dt.month
df['day_of_week'] = df['timestamp'].dt.dayofweek

# Seasonal factor
seasonal_factor = 0.5 + 0.5 * np.sin(2 * np.pi * (df['day_of_year'] - 80) / 365.0)
seasonal_factor = 0.6 + 0.8 * seasonal_factor

# Daily pattern
def daily_pattern(hour):
    if 0 <= hour < 6:
        return 0.6
    elif 6 <= hour < 10:
        return 0.9
    elif 10 <= hour < 16:
        return 0.8
    elif 16 <= hour < 18:
        return 0.9
    elif 18 <= hour < 22:
        return 1.4
    else:
        return 1.0

df['daily_factor'] = df['hour'].apply(daily_pattern)
df['weekend_factor'] = 1.0
df.loc[df['day_of_week'] >= 5, 'weekend_factor'] = 1.15

df['base_consumption'] = (BASE_CONSUMPTION * 
                          seasonal_factor * 
                          df['daily_factor'] * 
                          df['weekend_factor'])

# Add noise and Laplace noise (Differential Privacy)
np.random.seed(42)
df['random_noise'] = np.random.normal(0, RANDOM_NOISE_SCALE, len(df))
laplace_noise = np.random.laplace(0, 1.0 / EPSILON, len(df))
df['consumption_kwh'] = df['base_consumption'] + df['random_noise'] + laplace_noise
df['consumption_kwh'] = df['consumption_kwh'].clip(lower=0.0)

# Simulate weather data
def temperature(day):
    return 20 + 15 * np.sin(2 * np.pi * (day - 80) / 365.0) + np.random.normal(0, 2)

def humidity(day, temp):
    base = 70 - 0.5 * (temp - 20)
    return np.clip(base + np.random.normal(0, 10), 20, 100)

df['temperature_c'] = df['day_of_year'].apply(temperature)
df['humidity_percent'] = df.apply(lambda row: humidity(row['day_of_year'], row['temperature_c']), axis=1)

# Keep final columns
df_final = df[['timestamp', 'consumption_kwh', 'temperature_c', 'humidity_percent']]

print(df)


# Simulate demographic/behavioral data for households
# Each household has: id, number of residents, house_type (apartment/villa), income_level, and daily activity pattern
np.random.seed(123)
num_households = 100  # number of distinct households

household_ids = np.arange(1, num_households + 1)
num_residents = np.random.choice([1, 2, 3, 4, 5], size=num_households, p=[0.15, 0.3, 0.25, 0.2, 0.1])
house_type = np.random.choice(['apartment', 'villa'], size=num_households, p=[0.7, 0.3])
income_level = np.random.choice(['low', 'medium', 'high'], size=num_households, p=[0.2, 0.5, 0.3])

# Behavioral pattern: working hours (0=day shift, 1=night shift, 2=mixed)
activity_pattern = np.random.choice([0, 1, 2], size=num_households, p=[0.6, 0.2, 0.2])

# Create DataFrame
household_df = pd.DataFrame({
    'household_id': household_ids,
    'num_residents': num_residents,
    'house_type': house_type,
    'income_level': income_level,
    'activity_pattern': activity_pattern
})

# Apply Differential Privacy: add Laplace noise to numerical column (num_residents)
# Since num_residents is integer, we round after adding noise
# Also we can add noise to other categorical? DP usually applies to numerical queries, but for simulation we can add noise to the count.
noisy_residents = np.round(household_df['num_residents'] + np.random.laplace(0, 1.0/EPSILON, len(household_df)))
noisy_residents = noisy_residents.clip(lower=1)  # at least 1 resident
household_df['num_residents_dp'] = noisy_residents.astype(int)

# For categorical, we can use randomized response or other mechanisms, but for simplicity we skip.
# We'll store both original and DP-protected version (original for reference, DP for analysis)
household_df['num_residents_original'] = household_df['num_residents']
household_df = household_df.drop(columns=['num_residents'])  # keep only DP version as main

print(household_df)


conn = pymysql.connect(
    host=DB_HOST,
    user=DB_USER,
    password=DB_PASSWORD,
    database=DB_NAME,
    port=DB_PORT,
    charset='utf8mb4'
)
cursor = conn.cursor()

schema_file = '../data/schema.sql'

with open(schema_file, 'r') as f:
    schema_sql = f.read()
    # Split into statements (simple split by ';')
    for statement in schema_sql.split(';'):
        if statement.strip():
            cursor.execute(statement)
conn.commit()


# Insert energy consumption data
df_final['timestamp'] = df_final['timestamp'].astype(str)
for _, row in df_final.iterrows():
    cursor.execute(
        "INSERT INTO energy_consumption (timestamp, consumption_kwh, temperature_c, humidity_percent) "
        "VALUES (%s, %s, %s, %s)",
        (row['timestamp'], row['consumption_kwh'], row['temperature_c'], row['humidity_percent'])
    )
conn.commit()


# Insert household data (num_residents is the DP-protected version)
for _, row in household_df.iterrows():
    cursor.execute(
        "INSERT INTO households (household_id, num_residents, house_type, income_level, activity_pattern, num_residents_original) "
        "VALUES (%s, %s, %s, %s, %s, %s)",
        (row['household_id'], row['num_residents_dp'], row['house_type'], row['income_level'],
         row['activity_pattern'], row['num_residents_original'])
    )
conn.commit()



